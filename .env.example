# Book Intelligence Agent — Environment Variables
# Copy this to .env and fill in your values

# Required: Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Database URL (Railway provides this automatically when you add PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/book_intelligence

# Optional: Claude model to use (default: claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional: Max tokens for Claude responses (default: 8192)
CLAUDE_MAX_TOKENS=8192

# Optional: Debug mode (default: false)
DEBUG=false
